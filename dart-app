async function speakElevenLabs(text, apiKey, voiceId){
  apiKey = apiKey || elApiKey;
  voiceId = voiceId || elVoiceId;
  const response = await fetch('https://dartsapp.esafrany13.workers.dev/', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ text, voiceId, apiKey })
  });
  if(!response.ok){
    const err = await response.text();
    throw new Error(`${response.status}: ${err}`);
  }
  const blob = await response.blob();
  const url = URL.createObjectURL(blob);
  return new Promise((resolve, reject) => {
    const audio = new Audio(url);
    audio.onended = () => { URL.revokeObjectURL(url); resolve(); };
    audio.onerror = (e) => { URL.revokeObjectURL(url); reject(new Error('Audio play failed')); };
    audio.play().catch(reject);
  });
}

function speakWebSpeech(text){
  if(!window.speechSynthesis) return;
  speechSynthesis.cancel();
  const u = new SpeechSynthesisUtterance(text);
  if(huVoice) u.voice = huVoice;
  u.lang = 'hu-HU';
  u.rate = 1.05;
  u.pitch = 1;
  speechSynthesis.speak(u);
}

function speak(text){
  if(!voiceEnabled) return;
  if(elApiKey){
    speakElevenLabs(text).catch(()=>speakWebSpeech(text));
  } else {
    speakWebSpeech(text);
  }
}

// Number to Hungarian words for TTS
function numHU(n){
  const ones=['nulla','egy','kettő','három','négy','öt','hat','hét','nyolc','kilenc',
    'tíz','tizenegy','tizenkettő','tizenhárom','tizennégy','tizenöt','tizenhat','tizenhét','tizennyolc','tizenkilenc'];
  const tens=['','','húsz','harminc','negyven','ötven','hatvan','hetven','nyolcvan','kilencven'];
  if(n<20) return ones[n];
  if(n<100){
    const t=Math.floor(n/10), o=n%10;
    if(o===0) return tens[t];
    return (t===2?'huszon':tens[t])+ones[o];
  }
  if(n===100) return 'száz';
  if(n<200){
    const r=n-100;
    if(r===0) return 'száz';
    return 'száz'+numHU(r);
  }
  // 101-180
  const h=Math.floor(n/100), r=n%100;
  return ones[h]+'száz'+(r>0?numHU(r):'');
}

function announceScore(score, remaining, bust){
  if(bust){ speak('Bust!'); return; }
  if(remaining===0){ speak('Checkout!'); return; }
  if(score===180){ speak('One hundred and eighty!'); return; }
  // Only say remaining if under 200
  if(remaining < 200){
    speak(`${score}. ${remaining} remaining.`);
  } else {
    speak(String(score));
  }
}

