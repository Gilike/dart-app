// ===== GAME =====
function startGame(players, mode, legs, startPlayerIdx=0){
  const pubLimit = mode===501 ? 60 : 42;
  legHistory = [];
  game = {
    mode, legs, pubLimit,
    isPubGame:false,
    pubState:null,
    players: players.map(name=>({
      name, score:mode,
      legsWon:0,
      dartsThrown:0, pointsScored:0,
      legDartsThrown:0,
    })),
    currentPlayer: startPlayerIdx % players.length,
    roundNumber:1,
    log:[],
    legLog:[], // current leg turns
    firstPlayerOfLeg: startPlayerIdx % players.length,
    undoStack:[], // for undo
    _tourneyMatchIdx: undefined,
  };
  currentInput=''; pubInput='';
  renderGame();
  showScreen('screen-game');
  // Announce first player
  speak(`${players[startPlayerIdx % players.length]} kezd!`);
}

function calcAvg(pts,darts){ return darts>0?((pts/darts)*3).toFixed(1):'-'; }

function renderGame(){
  document.getElementById('gameBadge').textContent=game.mode;
  const needed=Math.ceil(game.legs/2);
  document.getElementById('gameInfo').innerHTML=`KÖR ${game.roundNumber}<br>${game.isPubGame?'🍺 PUB':`${needed}/${game.legs} láb`}`;
  document.getElementById('pubgameBanner').style.display=game.isPubGame?'block':'none';
  document.getElementById('normalNumpad').style.display=game.isPubGame?'none':'block';
  document.getElementById('pubNumpad').style.display=game.isPubGame?'block':'none';

  // Undo button
  const undoBtn=document.getElementById('undoBtn');
  if(undoBtn) undoBtn.disabled = game.undoStack.length===0 || game.isPubGame;

  const count=game.players.length;
  const grid=document.getElementById('playersGrid');
  grid.className=count===1?'players-grid cols1':count===3?'players-grid cols3':'players-grid';
  grid.innerHTML=game.players.map((p,i)=>{
    const isActive=i===game.currentPlayer&&!game.isPubGame;
    const won=p.legsWon>=needed;
    return `<div class="player-card ${isActive?'active':''} ${won?'won':''}">
      ${isActive?'<div class="active-dot"></div>':''}
      <div class="p-name">${esc(p.name)}</div>
      <div class="p-score">${p.score}</div>
      <div class="p-meta">🎯 ${p.legDartsThrown} nyíl</div>
      <div class="p-meta">${'●'.repeat(p.legsWon)}${'○'.repeat(Math.max(0,game.legs-p.legsWon))} (${p.legsWon}/${needed})</div>
      <div class="p-meta">Ø ${calcAvg(p.pointsScored,p.dartsThrown)}</div>
    </div>`;
  }).join('');

  if(game.isPubGame) renderPubDisplay();
  renderRoundLog();
  renderInputDisplay();
  renderCheckoutHint();
}

function renderCheckoutHint(){
  const el=document.getElementById('checkoutHint');
  if(!el||game.isPubGame){if(el)el.style.display='none';return;}
  const player=game.players[game.currentPlayer];
  const rem=player.score;
  if(rem<=170 && rem>=2 && CHECKOUT[rem]){
    el.style.display='block';
    el.innerHTML=`<strong>🎯 CHECKOUT — ${rem}</strong>${CHECKOUT[rem]}`;
  } else {
    el.style.display='none';
  }
}

function renderInputDisplay(){
  if(game.isPubGame) return;
  const val=document.getElementById('cinValue');
  const res=document.getElementById('cinResult');
  const player=game.players[game.currentPlayer];
  val.textContent=currentInput||'-';
  if(currentInput && parseInt(currentInput)>0){
    const score=parseInt(currentInput);
    const err=getScoreError(score);
    if(err){ res.textContent=err; res.className='cin-result invalid'; }
    else {
      const rem=player.score-score;
      if(rem<0||rem===1){ res.textContent='BUST! 💥'; res.className='cin-result bust'; }
      else if(rem===0){ res.textContent='🎯 CHECKOUT!'; res.className='cin-result valid'; }
      else { res.textContent=`Marad: ${rem}`; res.className='cin-result valid'; }
    }
  } else { res.textContent=''; res.className='cin-result'; }
}

