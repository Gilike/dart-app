// ===== GAME HELPERS =====
function advancePlayer(){
  game.currentPlayer=(game.currentPlayer+1)%game.players.length;
  if(game.currentPlayer===game.firstPlayerOfLeg) game.roundNumber++;
}
function resetLeg(){
  game.players.forEach(p=>{ p.score=game.mode; p.legDartsThrown=0; });
  game.firstPlayerOfLeg=(game.firstPlayerOfLeg+1)%game.players.length;
  game.currentPlayer=game.firstPlayerOfLeg;
  game.roundNumber++;
}

// ===== PUB GAME =====
function triggerPubGame(){
  game.isPubGame=true;
  game.pubState={scores:game.players.map(p=>({name:p.name,score:null})),currentIdx:0};
  pubInput='';
  showToast('🍺 PUB GAME INDUL!',2500);
  speak('Pub Game! Három nyíl, legtöbb pont nyer!');
  renderGame();
}
function renderPubDisplay(){
  const el=document.getElementById('pubScoresDisplay');
  el.innerHTML=game.pubState.scores.map((s,i)=>{
    const isActive=i===game.pubState.currentIdx&&s.score===null;
    return `<div class="pub-player-score ${isActive?'active-pub':''}">
      <div class="pps-name">${esc(s.name)}</div>
      <div class="pps-val ${s.score!==null?'done':''}">${s.score!==null?s.score:(isActive?(pubInput||'-'):'?')}</div>
    </div>`;
  }).join('');
}
function pubNumInput(d){ if(pubInput.length>=3)return; pubInput+=d; renderPubDisplay(); }
function pubNumDel(){ pubInput=pubInput.slice(0,-1); renderPubDisplay(); }
function pubSubmit(){
  if(!pubInput) return;
  const score=parseInt(pubInput);
  const err=getScoreError(score);
  if(err){ showToast(err); pubInput=''; renderPubDisplay(); return; }
  const ps=game.pubState;
  ps.scores[ps.currentIdx].score=score;
  game.log.push({player:ps.scores[ps.currentIdx].name,score,bust:false,remaining:0,pub:true});
  speak(`${numHU(score)}`);
  pubInput=''; ps.currentIdx++;
  if(ps.currentIdx>=ps.scores.length){
    const sorted=[...ps.scores].sort((a,b)=>b.score-a.score);
    const topScore=sorted[0].score;
    const tied=sorted.filter(s=>s.score===topScore);
    if(tied.length>1){
      showToast(`🔄 Döntetlen! Újra dobnak: ${tied.map(s=>s.name).join(', ')}`,3000);
      speak('Döntetlen! Újra dobnak!');
      game.pubState={scores:tied.map(s=>({name:s.name,score:null})),currentIdx:0};
      pubInput=''; renderGame(); return;
    }
    const winnerName=sorted[0].name;
    const winPlayer=game.players.find(p=>p.name===winnerName);
    if(winPlayer){
      winPlayer.legsWon++;
      game.log.push({player:winnerName,score:topScore,bust:false,remaining:0,pub:true,won:true});
      saveLegToHistory(winnerName);
      const needed=Math.ceil(game.legs/2);
      if(winPlayer.legsWon>=needed){ endGame(winPlayer,true); return; }
      showToast(`🍺 ${winnerName} nyerte a lábat!`);
      speak(`${winnerName} nyerte a lábat!`);
      game.isPubGame=false; game.pubState=null;
      resetLeg(); renderGame();
    }
  } else {
    // Announce next player
    const next=game.pubState.scores[game.pubState.currentIdx];
    speak(`${next.name} következik!`);
    renderGame();
  }
}

// ===== END GAME =====
function endGame(winner, isPub){
  const s=state.stats;
  if(!s[winner.name]) s[winner.name]={wins:0,games:0,totalDarts:0,totalPoints:0,pubWins:0};
  s[winner.name].wins++;
  if(isPub) s[winner.name].pubWins=(s[winner.name].pubWins||0)+1;
  game.players.forEach(p=>{
    if(!s[p.name]) s[p.name]={wins:0,games:0,totalDarts:0,totalPoints:0,pubWins:0};
    s[p.name].games++;
    s[p.name].totalDarts=(s[p.name].totalDarts||0)+p.dartsThrown;
    s[p.name].totalPoints=(s[p.name].totalPoints||0)+p.pointsScored;
  });
  // Update tourney bracket if applicable
  if(game._tourneyMatchIdx!==undefined && state.tournament){
    const idx=game._tourneyMatchIdx;
    const m=state.tournament.matches[idx];
    if(m){
      const losePlayer=game.players.find(p=>p.name!==winner.name);
      m.legsP1=m.p1===winner.name?winner.legsWon:(losePlayer?losePlayer.legsWon:0);
      m.legsP2=m.p2===winner.name?winner.legsWon:(losePlayer?losePlayer.legsWon:0);
      m.winner=winner.name;
      m.loser=losePlayer?losePlayer.name:'';
      m.status='done';
    }
  }
  saveState();
  speak(`${winner.name} nyert! Gratulálok!`);
  const avg=calcAvg(winner.pointsScored,winner.dartsThrown);
  document.getElementById('winName').textContent=winner.name;
  document.getElementById('winMethod').textContent=isPub?'🍺 PUB GAME-EN NYERT!':'NYERT!';
  document.getElementById('winStats').innerHTML=`
    <div class="stat-row"><span class="sr-label">Győzelem</span><span class="sr-val">${isPub?'🍺 PubGame':'🎯 Normál'}</span></div>
    <div class="stat-row"><span class="sr-label">Lábak megnyerve</span><span class="sr-val">${winner.legsWon}</span></div>
    <div class="stat-row"><span class="sr-label">Eldobott nyilak</span><span class="sr-val">${winner.dartsThrown}</span></div>
    <div class="stat-row"><span class="sr-label">3-nyilas átlag</span><span class="sr-val">${avg}</span></div>
    <div class="stat-row"><span class="sr-label">Játékmód</span><span class="sr-val">${game.mode}</span></div>`;
  showScreen('screen-win');
}

function startRematch(){
  const pl=game.players.map(p=>p.name), m=game.mode, l=game.legs;
  bullState={players:pl,selectedIdx:null,pendingGameArgs:[pl,m,l]};
  renderBullScreen(); showScreen('screen-bull');
}
function confirmQuit(){ document.getElementById('quitModal').classList.add('show'); }
function quitGame(){ closeModal('quitModal'); showScreen('screen-home'); }

// ===== TOURNAMENT =====
function onTourneyTypeChange(){
  const type=document.getElementById('tourneyType').value;
  const infoEl=document.getElementById('tourneyTypeInfo');
  const groupWrap=document.getElementById('groupSettingsWrap');
  if(type==='roundrobin'){
    infoEl.textContent='🔄 Mindenki mindenki ellen játszik egyszer. PDC rangsorolás.';
    groupWrap.style.display='none';
  } else if(type==='groups'){
    infoEl.textContent='🏆 Csoportkör + kieséses. Állítsd be a csoportok és játékosok számát.';
    groupWrap.style.display='block';
    onGroupSettingChange();
  } else {
    infoEl.textContent='⚡ Vesztes kiesik, egyenes kieséses torna.';
    groupWrap.style.display='none';
  }
}
function onGroupSettingChange(){
  const gc=parseInt(document.getElementById('groupCount').value);
  const pp=parseInt(document.getElementById('playersPerGroup').value);
  document.getElementById('groupCalcInfo').textContent=`ℹ️ ${gc} csoport × ${pp} fő = ${gc*pp} játékos szükséges`;
}
function renderTourneyScreen(){
  tourneyPlayers=[];
  renderTourneyPlayers();
  onTourneyTypeChange();
  const el=document.getElementById('savedForTourney');
  if(state.players.length){
    el.innerHTML='<div class="input-label" style="margin-bottom:5px">MENTETT JÁTÉKOSOK</div>' +
      '<div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:6px">' +
      state.players.map(p=>`<button class="quick-btn" style="flex:none;padding:5px 10px" onclick="addTourneyPlayerByName('${esc(p).replace(/'/g,"\\'")}')"> ${esc(p)}</button>`).join('')+'</div>';
  } else el.innerHTML='';
  renderBracket();
}
function addTourneyPlayer(){
  const el=document.getElementById('tourneyPlayerName');
  const name=el.value.trim(); if(!name)return;
  addTourneyPlayerByName(name); el.value='';
}
function addTourneyPlayerByName(name){
  if(tourneyPlayers.length>=32){showToast('⚠️ Maximum 32!');return;}
  if(tourneyPlayers.includes(name)){showToast('⚠️ Már hozzáadva!');return;}
  tourneyPlayers.push(name); renderTourneyPlayers();
}
function removeTourneyPlayer(i){ tourneyPlayers.splice(i,1); renderTourneyPlayers(); }
function renderTourneyPlayers(){
  const el=document.getElementById('tourneyPlayerList');
  const ce=document.getElementById('tourneyCount');
  if(!tourneyPlayers.length){el.innerHTML='';ce.textContent='';return;}
  el.innerHTML=tourneyPlayers.map((p,i)=>`
    <div class="player-tag">
      <span class="name">🎯 ${esc(p)}</span>
      <button class="remove-btn" onclick="removeTourneyPlayer(${i})">×</button>
    </div>`).join('');
  ce.textContent=`${tourneyPlayers.length} játékos`;
}
function generateTourney(){
  if(tourneyPlayers.length<2){showToast('⚠️ Legalább 2 játékos!');return;}
  const type=document.getElementById('tourneyType').value;
  const mode=document.getElementById('tourneyMode').value;
  const shuffled=[...tourneyPlayers].sort(()=>Math.random()-.5);
  let matches=[],groups=[],advancePerGroup=2;
  if(type==='roundrobin'){
    matches=genRoundRobin(shuffled);
  } else if(type==='groups'){
    const gc=parseInt(document.getElementById('groupCount').value);
    const pp=parseInt(document.getElementById('playersPerGroup').value);
    advancePerGroup=parseInt(document.getElementById('advancePerGroup').value);
    const needed=gc*pp;
    if(shuffled.length<needed){showToast(`⚠️ Kell ${needed} játékos (${shuffled.length} van)!`,3000);return;}
    const used=shuffled.slice(0,needed);
    groups=splitGroups(used,gc,pp);
    groups.forEach((g,gi)=>{
      genRoundRobin(g).forEach(m=>matches.push({...m,group:gi}));
    });
  } else {
    matches=genKnockout(shuffled);
  }
  state.tournament={type,mode,matches,groups,players:shuffled,advancePerGroup,createdAt:new Date().toLocaleDateString('hu-HU')};
  saveState(); renderBracket(); switchTab('tbracket'); showToast('🎲 Sorsolás kész!');
}
function genRoundRobin(players){
  const m=[];
  for(let i=0;i<players.length;i++)
    for(let j=i+1;j<players.length;j++)
      m.push({p1:players[i],p2:players[j],status:'pending',winner:null,loser:null,legsP1:0,legsP2:0,phase:'rr'});
  return m;
}
function genKnockout(players){
  const m=[];
  for(let i=0;i<players.length-1;i+=2)
    m.push({p1:players[i],p2:players[i+1],status:'pending',winner:null,loser:null,legsP1:0,legsP2:0,phase:'ko',round:1});
  if(players.length%2!==0){
    const last=players[players.length-1];
    m.push({p1:last,p2:'BYE',status:'done',winner:last,loser:'BYE',legsP1:3,legsP2:0,phase:'ko',round:1});
  }
  return m;
}
function splitGroups(players,numGroups,perGroup){
  const groups=Array.from({length:numGroups},()=>[]);
  players.forEach((p,i)=>groups[i%numGroups].push(p));
  return groups;
}

// ===== STANDINGS (PDC rules) =====
function calcGroupStandings(players,matches){
  const st={};
  players.forEach(p=>{ st[p]={name:p,played:0,wins:0,losses:0,legsFor:0,legsAgainst:0}; });
  matches.forEach(m=>{
    if(m.status!=='done'||!m.winner||m.p2==='BYE') return;
    const w=m.winner, l=(w===m.p1?m.p2:m.p1);
    const wL=(w===m.p1?m.legsP1:m.legsP2)||0;
    const lL=(w===m.p1?m.legsP2:m.legsP1)||0;
    [w,l].forEach(n=>{ if(!st[n]) st[n]={name:n,played:0,wins:0,losses:0,legsFor:0,legsAgainst:0}; });
    st[w].played++;st[w].wins++;st[w].legsFor+=wL;st[w].legsAgainst+=lL;
    st[l].played++;st[l].losses++;st[l].legsFor+=lL;st[l].legsAgainst+=wL;
  });
  const rows=Object.values(st);
  rows.sort((a,b)=>{
    if(b.wins!==a.wins) return b.wins-a.wins;
    const da=a.legsFor-a.legsAgainst, db=b.legsFor-b.legsAgainst;
    if(db!==da) return db-da;
    const hth=headToHead(a.name,b.name,matches);
    if(hth!==0) return hth;
    return b.legsFor-a.legsFor;
  });
  return rows;
}
function headToHead(nameA,nameB,matches){
  const m=matches.find(m=>(m.p1===nameA&&m.p2===nameB)||(m.p1===nameB&&m.p2===nameA));
  if(!m||m.status!=='done') return 0;
  return m.winner===nameA?-1:m.winner===nameB?1:0;
}

// ===== BRACKET =====
function renderBracket(){
  const el=document.getElementById('bracketList');
  const actEl=document.getElementById('bracketActions');
  if(!state.tournament){
    el.innerHTML='<div class="empty-state"><div class="es-icon">🎲</div><div class="es-text">Még nincs torna sorsolva</div></div>';
    actEl.style.display='none'; return;
  }
  actEl.style.display='block';
  const t=state.tournament;
  let html=`<div style="font-family:'Barlow Condensed',sans-serif;font-size:12px;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:9px">${t.createdAt} · ${t.mode}</div>`;
  if(t.type==='groups'&&t.groups&&t.groups.length){
    const letters=['A','B','C','D','E','F','G','H'];
    t.groups.forEach((group,gi)=>{
      html+=`<div class="group-header">📋 ${letters[gi]} CSOPORT</div>`;
      t.matches.filter(m=>m.group===gi).forEach(m=>{ html+=renderMatchCard(m,t.matches.indexOf(m)); });
    });
  } else {
    t.matches.forEach((m,i)=>{ html+=renderMatchCard(m,i); });
  }
  el.innerHTML=html;
}
function renderMatchCard(m,idx){
  const done=m.status==='done';
  const sc=done&&m.legsP1!=null?` (${m.legsP1}:${m.legsP2})`:'';
  return `<div class="bracket-card">
    <div class="bracket-vs">
      <span class="bv-name">${esc(m.p1)}</span>
      <span class="bv-vs">VS</span>
      <span class="bv-name" style="text-align:right">${esc(m.p2)}</span>
    </div>
    <div class="bracket-actions">
      ${done?`<span class="bracket-status bs-done">✓ ${esc(m.winner)}${sc}</span>`:
        m.p2==='BYE'?`<span class="bracket-status bs-done">BYE</span>`:
        `<button class="btn btn-primary btn-xs" onclick="startTourneyMatch(${idx})">MECCS</button>
         <button class="btn btn-ghost btn-xs" onclick="openResultModal(${idx})">EREDMÉNY</button>`}
    </div>
  </div>`;
}

let pendingResultIdx=null;
function openResultModal(idx){
  pendingResultIdx=idx;
  const m=state.tournament.matches[idx];
  let modal=document.getElementById('resultModal');
  if(!modal){
    const div=document.createElement('div');
    div.id='resultModal'; div.className='modal-overlay';
    div.innerHTML=`<div class="modal-box">
      <div class="modal-title">EREDMÉNY</div>
      <div style="color:var(--muted);font-size:13px;margin-bottom:11px" id="resultModalSub"></div>
      <div class="input-group"><label class="input-label" id="resultLabelP1"></label><input type="number" id="resultLegsP1" min="0" max="10" placeholder="0"></div>
      <div class="input-group"><label class="input-label" id="resultLabelP2"></label><input type="number" id="resultLegsP2" min="0" max="10" placeholder="0"></div>
      <div class="modal-actions">
        <button class="btn btn-primary btn-sm" onclick="saveResult()">MENTÉS</button>
        <button class="btn btn-secondary btn-sm" onclick="closeModal('resultModal')">MÉGSEM</button>
      </div>
    </div>`;
    document.body.appendChild(div);
  }
  document.getElementById('resultModalSub').textContent=`${m.p1} vs ${m.p2}`;
  document.getElementById('resultLabelP1').textContent=`${m.p1} nyert lábak`;
  document.getElementById('resultLabelP2').textContent=`${m.p2} nyert lábak`;
  document.getElementById('resultLegsP1').value='';
  document.getElementById('resultLegsP2').value='';
  document.getElementById('resultModal').classList.add('show');
}
function saveResult(){
  const l1=parseInt(document.getElementById('resultLegsP1').value)||0;
  const l2=parseInt(document.getElementById('resultLegsP2').value)||0;
  if(l1===l2){showToast('⚠️ Döntetlen nem lehetséges!');return;}
  const m=state.tournament.matches[pendingResultIdx];
  m.legsP1=l1; m.legsP2=l2;
  m.winner=l1>l2?m.p1:m.p2;
  m.loser=l1>l2?m.p2:m.p1;
  m.status='done';
  saveState(); closeModal('resultModal'); renderBracket();
  showToast(`✅ ${m.winner} nyert!`);
}
function startTourneyMatch(i){
  const m=state.tournament.matches[i];
  bullState={players:[m.p1,m.p2],selectedIdx:null,pendingGameArgs:[[m.p1,m.p2],parseInt(state.tournament.mode),3,i]};
  renderBullScreen(); showScreen('screen-bull');
}
function clearTournament(){ state.tournament=null; saveState(); renderBracket(); showToast('Torna törölve'); }

// ===== STANDINGS RENDER =====
function renderStandings(){
  const el=document.getElementById('standingsList');
  if(!state.tournament){ el.innerHTML='<div class="empty-state"><div class="es-icon">📋</div><div class="es-text">Nincs aktív torna</div></div>'; return; }
  const t=state.tournament;
  const adv=t.advancePerGroup||2;
  if(t.type==='groups'&&t.groups&&t.groups.length){
    const letters=['A','B','C','D','E','F','G','H'];
    el.innerHTML=t.groups.map((group,gi)=>{
      const gm=t.matches.filter(m=>m.group===gi);
      const rows=calcGroupStandings(group,gm);
      return `<div class="group-header">📋 ${letters[gi]} CSOPORT</div>
              <div class="qualify-note">✓ Top ${adv} továbbjut</div>
              ${renderStandingsTable(rows,adv)}`;
    }).join('');
  } else {
    el.innerHTML=renderStandingsTable(calcGroupStandings(t.players,t.matches),0);
  }
}
function renderStandingsTable(rows,qualifyCount=0){
  return `<table class="rr-table">
    <tr><th>#</th><th>Játékos</th><th>J</th><th>Gy</th><th>V</th><th>LF</th><th>LA</th><th>LD</th></tr>
    ${rows.map((r,i)=>{
      const diff=r.legsFor-r.legsAgainst, q=qualifyCount>0&&i<qualifyCount;
      return `<tr class="${q?'qualified':''}">
        <td class="rr-pos">${q?'✓':i+1}</td>
        <td>${esc(r.name)}</td><td>${r.played}</td>
        <td class="rr-win">${r.wins}</td>
        <td style="color:var(--accent)">${r.losses}</td>
        <td>${r.legsFor}</td><td>${r.legsAgainst}</td>
        <td class="rr-diff ${diff>0?'pos':diff<0?'neg':''}">${diff>0?'+':''}${diff}</td>
      </tr>`;
    }).join('')}
  </table>
  <div style="font-family:'Barlow Condensed',sans-serif;font-size:11px;color:var(--muted);letter-spacing:1px;margin-bottom:4px">J=Játszott · Gy=Győzelem · V=Vereség · LF=Leg nyert · LA=Leg kapott · LD=Leg különbség</div>`;
}

// ===== LEADERBOARD =====
function renderLeaderboard(){
  const lbEl=document.getElementById('leaderboardList');
  const dtEl=document.getElementById('detailStatsList');
  const entries=Object.entries(state.stats).sort((a,b)=>b[1].wins-a[1].wins);
  if(!entries.length){
    lbEl.innerHTML='<div class="empty-state"><div class="es-icon">📊</div><div class="es-text">Még nincsenek statisztikák</div></div>';
    dtEl.innerHTML=''; return;
  }
  const rc=['gold','silver','bronze'];
  lbEl.innerHTML=entries.map(([name,s],i)=>{
    const avg=s.totalDarts>0?((s.totalPoints/s.totalDarts)*3).toFixed(1):'-';
    return `<div class="lb-row">
      <div class="lb-rank ${rc[i]||''}">${i+1}</div>
      <div class="lb-info"><div class="lb-name">${esc(name)}</div><div class="lb-detail">${s.games} meccs · Ø ${avg}</div></div>
      <div class="lb-wins">${s.wins} 🏆</div>
    </div>`;
  }).join('');
  dtEl.innerHTML=entries.map(([name,s])=>{
    const avg=s.totalDarts>0?((s.totalPoints/s.totalDarts)*3).toFixed(1):'-';
    const wr=s.games>0?Math.round(s.wins/s.games*100):0;
    return `<div class="stat-card">
      <div class="sc-header"><div class="sc-name">${esc(name)}</div><div class="sc-wins">${s.wins} 🏆</div></div>
      <div class="stat-row"><span class="sr-label">Meccsek</span><span class="sr-val">${s.games}</span></div>
      <div class="stat-row"><span class="sr-label">Győzelmek</span><span class="sr-val">${s.wins}</span></div>
      <div class="stat-row"><span class="sr-label">Győzelmi %</span><span class="sr-val">${wr}%</span></div>
      <div class="stat-row"><span class="sr-label">3-nyilas átlag</span><span class="sr-val">${avg}</span></div>
      <div class="stat-row"><span class="sr-label">PubGame győzelmek</span><span class="sr-val">${s.pubWins||0}</span></div>
    </div>`;
  }).join('');
}
function confirmClearStats(){ document.getElementById('clearStatsModal').classList.add('show'); }
function clearStats(){ state.stats={}; saveState(); closeModal('clearStatsModal'); renderLeaderboard(); showToast('Statisztikák törölve'); }

