// ===== NUMPAD =====
function numInput(d){ if(currentInput.length>=3)return; currentInput+=d; renderInputDisplay(); }
function numDel(){ currentInput=currentInput.slice(0,-1); renderInputDisplay(); }
function quickScore(s){ currentInput=String(s); renderInputDisplay(); }

function submitScore(){
  if(!currentInput) return;
  const score=parseInt(currentInput);
  if(score===0){ currentInput=''; renderInputDisplay(); return; } // ignore 0
  const err=getScoreError(score);
  if(err){ showToast(err); currentInput=''; renderInputDisplay(); return; }

  const player=game.players[game.currentPlayer];
  const remaining=player.score-score;

  // Save undo snapshot
  game.undoStack.push({
    playerIdx: game.currentPlayer,
    scoreSnapshot: game.players.map(p=>({...p})),
    logLength: game.log.length,
    legLogLength: game.legLog.length,
    roundNumber: game.roundNumber,
    firstPlayerOfLeg: game.firstPlayerOfLeg,
    currentPlayer: game.currentPlayer,
    isPubGame: game.isPubGame,
  });
  if(game.undoStack.length>10) game.undoStack.shift();

  if(remaining<0||remaining===1){
    player.dartsThrown+=3; player.legDartsThrown+=3;
    game.log.push({player:player.name,score,bust:true,remaining:player.score});
    game.legLog.push({player:player.name,score,bust:true,remaining:player.score});
    announceScore(score, player.score, true);
  } else {
    player.score=remaining;
    player.dartsThrown+=3; player.legDartsThrown+=3;
    player.pointsScored+=score;
    game.log.push({player:player.name,score,bust:false,remaining});
    game.legLog.push({player:player.name,score,bust:false,remaining});
    announceScore(score, remaining, false);
    if(remaining===0){
      const needed=Math.ceil(game.legs/2);
      player.legsWon++;
      saveLegToHistory(player.name);
      if(player.legsWon>=needed){ endGame(player,false); return; }
      speak(`${player.name} nyerte a lábat!`);
      showToast(`🎯 ${player.name} nyerte a lábat!`);
      resetLeg(); currentInput=''; renderGame(); return;
    }
  }

  currentInput='';
  advancePlayer();
  if(!game.isPubGame && game.players.every(p=>p.legDartsThrown>=game.pubLimit)){
    triggerPubGame(); return;
  }
  renderGame();
}

// ===== UNDO =====
function undoLastScore(){
  if(!game||game.undoStack.length===0) return;
  const snap=game.undoStack.pop();
  // Restore player states
  game.players=snap.scoreSnapshot.map(p=>({...p}));
  game.log.splice(snap.logLength);
  game.legLog.splice(snap.legLogLength);
  game.roundNumber=snap.roundNumber;
  game.firstPlayerOfLeg=snap.firstPlayerOfLeg;
  game.currentPlayer=snap.currentPlayer;
  game.isPubGame=snap.isPubGame;
  currentInput='';
  showToast('↩ Visszavonva');
  renderGame();
}

