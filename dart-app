<!DOCTYPE html>
<html lang="hu">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#0a0a0f">
<title>🎯 DART PRO</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@400;600;700&family=Barlow:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:#0a0a0f;--surface:#12121a;--surface2:#1a1a26;--border:#2a2a3d;
    --accent:#ff3b3b;--accent2:#ff8c00;--gold:#ffd700;--green:#00e676;
    --blue:#4fc3f7;--text:#f0f0f8;--muted:#6b6b8a;--radius:12px;
  }
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
  body{background:var(--bg);color:var(--text);font-family:'Barlow',sans-serif;min-height:100vh;overflow-x:hidden}
  .screen{display:none;min-height:100vh;padding:16px;padding-bottom:40px;animation:fadeIn .25s ease}
  .screen.active{display:block}
  @keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

  /* HEADER */
  .app-header{text-align:center;padding:18px 0 6px}
  .app-title{font-family:'Bebas Neue',cursive;font-size:50px;letter-spacing:6px;background:linear-gradient(135deg,#ff3b3b,#ff8c00);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1}
  .app-subtitle{font-family:'Barlow Condensed',sans-serif;font-size:12px;letter-spacing:4px;color:var(--muted);text-transform:uppercase;margin-top:3px}
  .dart-icon{font-size:42px;display:block;margin-bottom:5px;animation:pulse 2s ease-in-out infinite}
  @keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.07)}}

  /* BUTTONS */
  .btn{display:block;width:100%;padding:14px 22px;border:none;border-radius:var(--radius);font-family:'Barlow Condensed',sans-serif;font-size:17px;font-weight:700;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all .15s}
  .btn:active{transform:scale(.97)}
  .btn-primary{background:linear-gradient(135deg,var(--accent),var(--accent2));color:white;box-shadow:0 4px 18px rgba(255,59,59,.28)}
  .btn-secondary{background:var(--surface2);color:var(--text);border:1px solid var(--border)}
  .btn-ghost{background:transparent;color:var(--muted);border:1px solid var(--border);font-size:14px;padding:10px 22px}
  .btn-danger{background:rgba(255,59,59,.1);color:var(--accent);border:1px solid rgba(255,59,59,.3)}
  .btn-blue{background:rgba(79,195,247,.12);color:var(--blue);border:1px solid rgba(79,195,247,.28)}
  .btn-green{background:rgba(0,230,118,.12);color:var(--green);border:1px solid rgba(0,230,118,.28)}
  .btn-sm{padding:9px 13px;font-size:14px;width:auto;display:inline-block}
  .btn-xs{padding:5px 9px;font-size:12px;width:auto;display:inline-block}

  /* CARDS & INPUTS */
  .card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:13px;margin-bottom:10px}
  .input-group{margin-bottom:11px}
  .input-label{font-family:'Barlow Condensed',sans-serif;font-size:12px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:4px;display:block}
  input[type=text],input[type=number],select{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'Barlow',sans-serif;font-size:16px;padding:10px 12px;outline:none;transition:border-color .2s;-webkit-appearance:none}
  input:focus,select:focus{border-color:var(--accent)}
  select option{background:var(--surface2)}
  .section-title{font-family:'Bebas Neue',cursive;font-size:25px;letter-spacing:3px;margin-bottom:13px}
  .section-title span{color:var(--accent)}
  .menu-grid{display:flex;flex-direction:column;gap:9px;margin-top:18px}

  /* PLAYER TAG */
  .player-tag{display:flex;align-items:center;justify-content:space-between;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:9px 13px;margin-bottom:7px;animation:slideIn .2s ease}
  @keyframes slideIn{from{opacity:0;transform:translateX(-6px)}to{opacity:1;transform:translateX(0)}}
  .player-tag .name{font-weight:600;font-size:15px}
  .player-tag .remove-btn{background:none;border:none;color:var(--accent);font-size:20px;cursor:pointer;padding:0 4px;line-height:1}

  /* BULL SCREEN */
  .bull-screen{text-align:center;padding:24px 0}
  .bull-icon{font-size:64px;display:block;margin-bottom:12px;animation:pulse 1.5s ease-in-out infinite}
  .bull-title{font-family:'Bebas Neue',cursive;font-size:34px;letter-spacing:4px;color:var(--accent);margin-bottom:6px}
  .bull-sub{font-family:'Barlow Condensed',sans-serif;font-size:14px;letter-spacing:2px;color:var(--muted);text-transform:uppercase;margin-bottom:20px}
  .bull-player-grid{display:flex;flex-direction:column;gap:8px;margin-bottom:16px}
  .bull-player-btn{background:var(--surface);border:2px solid var(--border);border-radius:var(--radius);padding:14px;font-family:'Barlow Condensed',sans-serif;font-size:18px;font-weight:700;letter-spacing:1px;color:var(--text);cursor:pointer;transition:all .15s;text-transform:uppercase}
  .bull-player-btn:active{transform:scale(.97)}
  .bull-player-btn.selected{border-color:var(--gold);background:rgba(255,215,0,.08);color:var(--gold)}
  .bull-player-btn.closest{border-color:var(--green);background:rgba(0,230,118,.08);color:var(--green)}

  /* GAME */
  .game-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:9px}
  .game-mode-badge{background:linear-gradient(135deg,var(--accent),var(--accent2));color:white;font-family:'Bebas Neue',cursive;font-size:19px;letter-spacing:3px;padding:3px 13px;border-radius:6px}
  .game-info-badge{font-family:'Barlow Condensed',sans-serif;font-size:12px;color:var(--muted);letter-spacing:1px;text-align:right}
  .pubgame-banner{background:linear-gradient(135deg,rgba(255,140,0,.18),rgba(255,59,59,.18));border:1px solid var(--accent2);border-radius:8px;padding:7px 13px;margin-bottom:9px;text-align:center;font-family:'Bebas Neue',cursive;font-size:19px;letter-spacing:3px;color:var(--accent2);animation:flashBg 1s ease-in-out infinite}
  @keyframes flashBg{0%,100%{opacity:1}50%{opacity:.6}}

  /* PLAYER CARDS */
  .players-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:7px;margin-bottom:9px}
  .players-grid.cols1{grid-template-columns:1fr}
  .players-grid.cols3{grid-template-columns:repeat(3,1fr)}
  .player-card{background:var(--surface);border:2px solid var(--border);border-radius:var(--radius);padding:9px 7px;text-align:center;transition:all .2s;position:relative}
  .player-card.active{border-color:var(--accent);background:rgba(255,59,59,.07);box-shadow:0 0 16px rgba(255,59,59,.16)}
  .player-card.won{border-color:var(--gold);background:rgba(255,215,0,.06)}
  .p-name{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:13px;letter-spacing:1px;color:var(--muted);text-transform:uppercase;margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .player-card.active .p-name{color:var(--accent)}
  .p-score{font-family:'Bebas Neue',cursive;font-size:40px;line-height:1;letter-spacing:2px}
  .player-card.active .p-score{color:var(--text)}
  .player-card:not(.active) .p-score{color:var(--muted)}
  .player-card.won .p-score{color:var(--gold)}
  .p-meta{font-size:10px;color:var(--muted);margin-top:1px}
  .active-dot{position:absolute;top:6px;right:6px;width:7px;height:7px;background:var(--accent);border-radius:50%;animation:blink 1s ease-in-out infinite}
  @keyframes blink{0%,100%{opacity:1}50%{opacity:.2}}

  /* NUMPAD */
  .numpad-section{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:11px;margin-bottom:9px}
  .cin-label{font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--muted);text-align:center;margin-bottom:2px}
  .cin-value{font-family:'Bebas Neue',cursive;font-size:48px;letter-spacing:4px;color:var(--accent);line-height:1;text-align:center;min-height:48px}
  .cin-result{font-family:'Barlow Condensed',sans-serif;font-size:13px;color:var(--muted);text-align:center;min-height:17px;margin-bottom:9px}
  .cin-result.valid{color:var(--green)}
  .cin-result.bust{color:var(--accent)}
  .cin-result.invalid{color:var(--accent2)}
  .quick-scores{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:7px}
  .quick-btn{background:var(--surface2);border:1px solid var(--border);border-radius:6px;color:var(--muted);font-family:'Barlow Condensed',sans-serif;font-size:13px;font-weight:600;padding:5px 6px;cursor:pointer;transition:all .1s;flex:1;text-align:center}
  .quick-btn:active{background:var(--accent);color:white;transform:scale(.91);border-color:var(--accent)}
  .numpad{display:grid;grid-template-columns:repeat(3,1fr);gap:6px}
  .num-btn{background:var(--surface2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'Bebas Neue',cursive;font-size:23px;letter-spacing:1px;padding:12px 6px;cursor:pointer;transition:all .1s}
  .num-btn:active{background:var(--border);transform:scale(.91)}
  .num-btn.btn-enter{background:linear-gradient(135deg,var(--accent),var(--accent2));color:white;grid-column:span 2;font-size:15px;box-shadow:0 3px 12px rgba(255,59,59,.22)}
  .num-btn.btn-del{background:rgba(255,59,59,.1);color:var(--accent);border-color:rgba(255,59,59,.2);font-size:17px}

  /* PUB GAME */
  .pubgame-input{background:var(--surface);border:2px solid var(--accent2);border-radius:var(--radius);padding:11px;margin-bottom:9px}
  .pub-title{font-family:'Bebas Neue',cursive;font-size:20px;letter-spacing:3px;color:var(--accent2);text-align:center;margin-bottom:7px}
  .pub-scores{display:flex;gap:7px;margin-bottom:9px}
  .pub-player-score{flex:1;text-align:center;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:9px 5px}
  .pub-player-score.active-pub{border-color:var(--accent2);background:rgba(255,140,0,.08)}
  .pps-name{font-family:'Barlow Condensed',sans-serif;font-size:11px;color:var(--muted);letter-spacing:1px;text-transform:uppercase}
  .pps-val{font-family:'Bebas Neue',cursive;font-size:30px;color:var(--accent2);line-height:1}
  .pps-val.done{color:var(--green)}

  /* ROUND LOG */
  .round-log{max-height:90px;overflow-y:auto}
  .round-log::-webkit-scrollbar{width:3px}
  .round-log::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
  .round-entry{display:flex;justify-content:space-between;align-items:center;padding:3px 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:12px}
  .re-player{color:var(--muted);font-weight:500;min-width:65px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  .re-score{color:var(--text);font-family:'Barlow Condensed',sans-serif;font-weight:600}
  .re-right{font-size:11px}
  .re-right.ok{color:var(--green)}
  .re-right.bust{color:var(--accent)}

  /* WIN */
  .win-screen{text-align:center;padding:28px 0}
  .win-trophy{font-size:68px;display:block;animation:winPop .55s cubic-bezier(.175,.885,.32,1.275)}
  @keyframes winPop{0%{transform:scale(0);opacity:0}60%{transform:scale(1.15)}100%{transform:scale(1);opacity:1}}
  .win-name{font-family:'Bebas Neue',cursive;font-size:50px;letter-spacing:4px;background:linear-gradient(135deg,var(--gold),var(--accent2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin:6px 0 2px}
  .win-sub{font-family:'Barlow Condensed',sans-serif;font-size:14px;letter-spacing:3px;text-transform:uppercase;color:var(--muted);margin-bottom:20px}

  /* STATS */
  .stat-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:13px;margin-bottom:9px}
  .sc-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:9px}
  .sc-name{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:16px;letter-spacing:1px;text-transform:uppercase}
  .sc-wins{font-family:'Bebas Neue',cursive;font-size:24px;color:var(--gold);letter-spacing:2px}
  .stat-row{display:flex;justify-content:space-between;padding:3px 0;font-size:13px;border-bottom:1px solid rgba(255,255,255,.04)}
  .stat-row:last-child{border-bottom:none}
  .sr-label{color:var(--muted)}
  .sr-val{font-weight:600}

  /* LEADERBOARD */
  .lb-row{display:flex;align-items:center;gap:9px;padding:10px 12px;background:var(--surface);border:1px solid var(--border);border-radius:8px;margin-bottom:7px}
  .lb-rank{font-family:'Bebas Neue',cursive;font-size:21px;min-width:24px;color:var(--muted);letter-spacing:1px}
  .lb-rank.gold{color:var(--gold)}
  .lb-rank.silver{color:#c0c0c0}
  .lb-rank.bronze{color:#cd7f32}
  .lb-info{flex:1}
  .lb-name{font-weight:600;font-size:15px}
  .lb-detail{font-size:11px;color:var(--muted);margin-top:1px}
  .lb-wins{font-family:'Bebas Neue',cursive;font-size:24px;color:var(--gold);letter-spacing:1px}

  /* TABS */
  .tabs{display:flex;gap:3px;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:3px;margin-bottom:13px}
  .tab-btn{flex:1;padding:7px 4px;border:none;border-radius:6px;background:transparent;color:var(--muted);font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:all .2s;font-weight:600}
  .tab-btn.active{background:linear-gradient(135deg,var(--accent),var(--accent2));color:white}
  .tab-content{display:none}
  .tab-content.active{display:block}

  /* TOURNAMENT */
  .group-header{font-family:'Bebas Neue',cursive;font-size:20px;letter-spacing:3px;color:var(--blue);margin:14px 0 7px}
  .bracket-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:11px;margin-bottom:7px}
  .bracket-vs{display:flex;align-items:center;gap:8px;font-family:'Barlow Condensed',sans-serif;font-size:14px;font-weight:700;text-transform:uppercase;margin-bottom:7px}
  .bv-name{flex:1}
  .bv-vs{color:var(--accent);font-size:11px;letter-spacing:2px}
  .bracket-actions{display:flex;gap:5px;flex-wrap:wrap}
  .bracket-status{font-size:12px;padding:3px 7px;border-radius:4px;font-family:'Barlow Condensed',sans-serif;letter-spacing:1px;font-weight:600}
  .bs-done{background:rgba(0,230,118,.1);color:var(--green)}

  /* STANDINGS TABLE */
  .rr-table{width:100%;border-collapse:collapse;font-size:12px;margin-bottom:12px}
  .rr-table th{background:var(--surface2);color:var(--muted);font-family:'Barlow Condensed',sans-serif;letter-spacing:1px;text-transform:uppercase;padding:5px 7px;text-align:left;border-bottom:1px solid var(--border)}
  .rr-table td{padding:6px 7px;border-bottom:1px solid rgba(255,255,255,.04)}
  .rr-table tr:last-child td{border-bottom:none}
  .rr-table .rr-pos{font-family:'Bebas Neue',cursive;font-size:16px;color:var(--muted)}
  .rr-table .rr-win{color:var(--green);font-weight:700}
  .rr-table .rr-diff.pos{color:var(--green)}
  .rr-table .rr-diff.neg{color:var(--accent)}
  .rr-table .qualified{background:rgba(0,230,118,.04)}
  .qualify-note{font-family:'Barlow Condensed',sans-serif;font-size:11px;color:var(--green);letter-spacing:1px;margin-bottom:8px}

  /* BACK + misc */
  .back-btn{background:none;border:none;color:var(--muted);font-family:'Barlow Condensed',sans-serif;font-size:13px;letter-spacing:1px;cursor:pointer;padding:0;display:flex;align-items:center;gap:5px;margin-bottom:13px}
  .back-btn:active{color:var(--text)}
  .sep{height:1px;background:var(--border);margin:14px 0}
  .empty-state{text-align:center;padding:30px 16px;color:var(--muted)}
  .es-icon{font-size:34px;margin-bottom:9px}
  .es-text{font-family:'Barlow Condensed',sans-serif;font-size:13px;letter-spacing:1px;text-transform:uppercase}
  .notice{background:rgba(79,195,247,.07);border:1px solid rgba(79,195,247,.22);border-radius:8px;padding:8px 12px;font-size:13px;color:var(--blue);margin-bottom:9px;font-family:'Barlow Condensed',sans-serif;letter-spacing:.5px}
  .notice.orange{background:rgba(255,140,0,.07);border-color:rgba(255,140,0,.22);color:var(--accent2)}

  /* MODAL */
  .modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:1000;align-items:center;justify-content:center;padding:16px}
  .modal-overlay.show{display:flex}
  .modal-box{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:20px;width:100%;max-width:340px;animation:modalIn .22s cubic-bezier(.175,.885,.32,1.275)}
  @keyframes modalIn{from{opacity:0;transform:scale(.88)}to{opacity:1;transform:scale(1)}}
  .modal-title{font-family:'Bebas Neue',cursive;font-size:22px;letter-spacing:3px;margin-bottom:10px}
  .modal-actions{display:flex;gap:7px;margin-top:12px}
  .modal-actions .btn{flex:1}

  /* TOAST */
  .toast{position:fixed;bottom:20px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:8px 16px;font-family:'Barlow Condensed',sans-serif;font-size:13px;letter-spacing:1px;color:var(--text);z-index:9999;transition:transform .3s cubic-bezier(.175,.885,.32,1.275);white-space:nowrap}
  .toast.show{transform:translateX(-50%) translateY(0)}

  /* CHECKOUT HINT */
  .checkout-hint{background:rgba(0,230,118,.07);border:1px solid rgba(0,230,118,.22);border-radius:8px;padding:7px 11px;margin-bottom:8px;font-family:'Barlow Condensed',sans-serif;font-size:13px;color:var(--green);letter-spacing:.5px}
  .checkout-hint strong{font-size:15px;display:block;margin-bottom:2px;letter-spacing:1px}

  /* UNDO BUTTON */
  .undo-btn{background:rgba(79,195,247,.1);border:1px solid rgba(79,195,247,.25);border-radius:8px;color:var(--blue);font-family:'Barlow Condensed',sans-serif;font-size:13px;font-weight:600;letter-spacing:1px;padding:7px 13px;cursor:pointer;width:100%;text-align:center;margin-bottom:8px;text-transform:uppercase}
  .undo-btn:active{background:rgba(79,195,247,.2);transform:scale(.98)}
  .undo-btn:disabled{opacity:.3;pointer-events:none}

  /* VOICE TOGGLE */
  .voice-toggle{display:flex;align-items:center;justify-content:space-between;background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:9px 13px;margin-bottom:8px}
  .vt-label{font-family:'Barlow Condensed',sans-serif;font-size:13px;letter-spacing:1px;color:var(--muted);text-transform:uppercase}
  .toggle-sw{position:relative;width:42px;height:24px;cursor:pointer}
  .toggle-sw input{opacity:0;width:0;height:0}
  .toggle-track{position:absolute;inset:0;background:var(--border);border-radius:12px;transition:.3s}
  .toggle-sw input:checked+.toggle-track{background:var(--accent)}
  .toggle-knob{position:absolute;top:3px;left:3px;width:18px;height:18px;background:white;border-radius:50%;transition:.3s}
  .toggle-sw input:checked~.toggle-knob{left:21px}

  /* LEG HISTORY MODAL */
  .leg-hist-entry{background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:10px 12px;margin-bottom:8px}
  .lhe-header{display:flex;justify-content:space-between;font-family:'Barlow Condensed',sans-serif;font-size:13px;letter-spacing:1px;text-transform:uppercase;color:var(--muted);margin-bottom:6px}
  .lhe-header span:last-child{color:var(--green)}
  .lhe-row{display:flex;justify-content:space-between;font-size:12px;padding:2px 0;border-bottom:1px solid rgba(255,255,255,.04)}
  .lhe-row:last-child{border-bottom:none}
  .lhe-player{color:var(--muted)}
  .lhe-pts{font-weight:600}
  .lhe-bust{color:var(--accent);font-size:11px}
  .lhe-rem{color:var(--green);font-size:11px}
</style>
</head>
<body>

<!-- HOME -->
<div id="screen-home" class="screen active">
  <div class="app-header">
    <span class="dart-icon">🎯</span>
    <div class="app-title">DART PRO</div>
    <div class="app-subtitle">Pontszámláló & Statisztikák</div>
  </div>
  <div class="menu-grid">
    <button class="btn btn-primary" onclick="showScreen('screen-setup')">🎯 ÚJ MECCS INDÍTÁSA</button>
    <button class="btn btn-secondary" onclick="showScreen('screen-tournament')">🏆 TORNA / SORSOLÁS</button>
    <button class="btn btn-secondary" onclick="showScreen('screen-leaderboard')">📊 STATISZTIKÁK</button>
    <button class="btn btn-ghost" onclick="showScreen('screen-players')">👥 JÁTÉKOSOK KEZELÉSE</button>
    <button class="btn btn-ghost" onclick="openVoiceSettings()">🔊 HANG BEÁLLÍTÁS</button>
  </div>
</div>

<!-- PLAYERS MANAGEMENT -->
<div id="screen-players" class="screen">
